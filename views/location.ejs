<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= location.name %> – Comparativa Climática</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%
    var cur     = weather && weather.current_weather;
    var curInfo = cur ? getWeatherInfo(cur.weathercode) : null;
    var tClass  = cur ? getTempClass(cur.temperature) : 'temp-mild';
  %>

  <header class="detail-header <%= tClass %> <%= location.colorClass %>">
    <div class="header-inner">
      <a href="/" class="back-btn">← Volver</a>
      <div class="detail-title">
        <span class="loc-flag-lg"><%= location.flag %></span>
        <div>
          <h1><%= location.name %></h1>
          <p><%= location.country || 'Territorio internacional' %></p>
        </div>
      </div>
      <% if (fromCache) { %>
        <span class="cache-pill">⚡ caché</span>
      <% } else { %>
        <span class="live-badge">● en vivo</span>
      <% } %>
    </div>
  </header>

  <main class="detail-container">
    <div class="detail-grid">

      <!-- Tiempo actual + previsión -->
      <% if (weather && cur) { %>
        <section class="card <%= tClass %> <%= location.colorClass %>">
          <p class="card-title">🌤️ Tiempo actual</p>
          <div class="cur-weather">
            <span class="cur-emoji"><%= curInfo.emoji %></span>
            <div>
              <div class="cur-temp"><%= Math.round(cur.temperature) %>°C</div>
              <div class="cur-cond"><%= curInfo.label %></div>
              <div class="cur-wind">💨 <%= Math.round(cur.windspeed) %> km/h</div>
            </div>
          </div>

          <p class="forecast-label">Previsión 5 días</p>
          <div class="forecast-row">
            <% for (var i = 0; i < weather.daily.time.length; i++) { %>
              <% var dayInfo = getWeatherInfo(weather.daily.weathercode[i]); %>
              <div class="forecast-cell">
                <div class="fc-date"><%= formatDate(weather.daily.time[i]) %></div>
                <div class="fc-icon"><%= dayInfo.emoji %></div>
                <div class="fc-temps">
                  <span class="fc-max"><%= Math.round(weather.daily.temperature_2m_max[i]) %>°</span>
                  <span class="fc-min"><%= Math.round(weather.daily.temperature_2m_min[i]) %>°</span>
                </div>
                <div class="fc-rain">🌧 <%= weather.daily.precipitation_sum[i] %> mm</div>
              </div>
            <% } %>
          </div>
        </section>
      <% } %>

      <!-- Datos del país -->
      <% if (country) { %>
        <section class="card">
          <p class="card-title">🗺️ País: <%= country.name.common %></p>
          <img src="<%= country.flags.svg %>" alt="Bandera" class="country-flag-img">
          <dl class="info-list">
            <% if (country.capital && country.capital[0]) { %>
              <div class="info-row"><dt>Capital</dt><dd><%= country.capital[0] %></dd></div>
            <% } %>
            <div class="info-row">
              <dt>Población</dt><dd><%= country.population.toLocaleString('es-ES') %></dd>
            </div>
            <div class="info-row">
              <dt>Área</dt>
              <dd><%= country.area ? country.area.toLocaleString('es-ES') + ' km²' : 'N/D' %></dd>
            </div>
            <% if (country.currencies) { %>
              <div class="info-row">
                <dt>Moneda</dt>
                <dd><%= Object.values(country.currencies).map(function(c){ return c.name + (c.symbol ? ' (' + c.symbol + ')' : ''); }).join(', ') %></dd>
              </div>
            <% } %>
            <% if (country.languages) { %>
              <div class="info-row">
                <dt>Idiomas</dt><dd><%= Object.values(country.languages).join(', ') %></dd>
              </div>
            <% } %>
            <div class="info-row">
              <dt>Región</dt>
              <dd><%= country.region %><% if (country.subregion) { %> · <%= country.subregion %><% } %></dd>
            </div>
            <% if (country.timezones) { %>
              <div class="info-row">
                <dt>Zona horaria</dt><dd><%= country.timezones.slice(0, 2).join(', ') %></dd>
              </div>
            <% } %>
          </dl>
        </section>
      <% } else { %>
        <section class="card">
          <p class="card-title">🗺️ Ubicación</p>
          <p class="no-country-text"><%= location.description %></p>
          <dl class="info-list" style="margin-top:1.2rem">
            <div class="info-row"><dt>Latitud</dt><dd>90° N</dd></div>
            <div class="info-row"><dt>Longitud</dt><dd>0° (meridiano de Greenwich)</dd></div>
            <div class="info-row"><dt>Estado</dt><dd>Aguas internacionales / hielo ártico</dd></div>
            <div class="info-row"><dt>Zona horaria</dt><dd>UTC</dd></div>
          </dl>
        </section>
      <% } %>

      <!-- Wikipedia -->
      <% if (wiki) { %>
        <section class="card card-full">
          <p class="card-title">📖 <%= wiki.title %> <span class="wiki-source">— Wikipedia</span></p>
          <div class="wiki-layout">
            <% if (wiki.thumbnail) { %>
              <img src="<%= wiki.thumbnail.source %>" alt="<%= wiki.title %>" class="wiki-img">
            <% } %>
            <div class="wiki-text">
              <p class="wiki-extract"><%= wiki.extract %></p>
              <a href="<%= wiki.content_urls.desktop.page %>" target="_blank" rel="noopener" class="wiki-link">
                Leer artículo completo en Wikipedia →
              </a>
            </div>
          </div>
        </section>
      <% } %>

    </div>

    <nav class="loc-nav">
      <p class="loc-nav-label">Otras ubicaciones</p>
      <div class="loc-nav-links">
        <% LOCATIONS.filter(function(l){ return l.id !== location.id; }).forEach(function(l) { %>
          <a href="/location/<%= l.id %>" class="loc-nav-btn"><%= l.flag %> <%= l.name %></a>
        <% }); %>
      </div>
    </nav>
  </main>

  <footer class="site-footer">
    <div class="api-dots">
      <span class="api-dot">Open-Meteo</span>
      <span class="api-dot">Wikipedia</span>
      <span class="api-dot">REST Countries</span>
    </div>
  </footer>

</body>
</html>
